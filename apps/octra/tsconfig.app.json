{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["@angular/localize"],
    "paths": {
      "@octra/annotation": ["libs/annotation/src/index.ts"],
      "@octra/assets": ["libs/assets/src/index.ts"],
      "@octra/json-sets": ["libs/json-sets/src/index.ts"],
      "@octra/media": ["libs/media/src/index.ts"],
      "@octra/ngx-components": ["libs/ngx-components/src/index.ts"],
      "@octra/ngx-utilities": ["libs/ngx-utilities/src/index.ts"],
      "@octra/utilities": ["libs/utilities/src/index.ts"],
      "@octra/web-media": ["libs/web-media/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"],
}
